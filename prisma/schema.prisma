generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String
  name       String?
  role       String   @default("user") // admin, hr, manager, user
  permissions String   @default("{}")   // JSON string: { "employees": "edit", "biometric": "read", ... }
  rank       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employees Employee[]
}

model Employee {
  id         String   @id @default(cuid())
  code       String?  // كود الموظف
  name       String
  department String?  // القسم
  position   String?   // الوظيفة
  shiftStart String? // بداية الدوام HH:MM
  shiftEnd   String? // نهاية الدوام HH:MM
  hireDate   String? // تاريخ التعيين DD/MM/YYYY
  mobile     String? // رقم الموبايل
  createdById String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  createdByIdUser User?  @relation(fields: [createdById], references: [id])
  biometrics     Biometric[]
  attendance     Attendance[]
  requests       Request[]
  qualityDeductions QualityDeduction[]
  travels TravelDeal[]
}

model Biometric {
  id         String   @id @default(cuid())
  employeeId String
  date       String   // DD/MM/YYYY
  checkIn    String?  // HH:MM
  checkOut   String?  // HH:MM
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
}

model Attendance {
  id         String   @id @default(cuid())
  employeeId String
  date       String   // DD/MM/YYYY
  status     String   @default("present") // present, late, absent, approved
  checkIn    String?
  checkOut   String?
  minutesLate Int     @default(0)
  notes      String?
  approvedRequestId String?
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
}

model Request {
  id         String   @id @default(cuid())
  employeeId String
  type       String   // leave, permission, excuse
  date       String   // DD/MM/YYYY
  reason     String
  status     String   @default("pending") // pending, approved, rejected
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
}

model DeductionRule {
  id       String  @id @default(cuid())
  key      String  @unique // late15, late30, late60, absence
  label    String
  amount   Float   // deduction amount in EGP or days
  unit     String  @default("EGP") // EGP, days
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QualityDeduction {
  id          String   @id @default(cuid())
  employeeId  String
  date        String   // DD/MM/YYYY
  type        String   // quality_issue, safety, compliance
  description String
  deductionDays  Float  @default(0)
  deductionAmount Float @default(0)
  evidence    String?  // URL or file reference
  month       String   // YYYY-MM for filtering
  createdAt   DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
}

model TravelDeal {
  id            String   @id @default(cuid())
  employeeId    String
  destination   String
  departureDate String   // DD/MM/YYYY
  returnDate    String?   // DD/MM/YYYY
  dealerName    String?   // اسم الديل
  customerNames String?   // اسماء العملاء المسافرين
  hasFlight     Boolean   @default(false)
  hasHotel      Boolean   @default(false)
  hasVisa       Boolean   @default(false)
  hasTours      Boolean   @default(false)
  hasTransportation Boolean @default(false)
  flightStatus   String? // booked, pending, missing
  hotelStatus    String? // booked, pending, missing
  visaStatus     String? // booked, pending, missing
  toursStatus    String? // booked, pending, missing
  transportationStatus String? // booked, pending, missing
  notes         String?
  status        String   @default("upcoming") // upcoming, in_progress, completed
  createdAt     DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
}
